ELEVEN_LABS_VOICE_ID=
VITA_API_KEY=123
WEBPUSH_VAPID_EMAIL=
WEBPUSH_VAPID_PUBLIC_KEY=
WEBPUSH_VAPID_PRIVATE_KEY=
SELF_EMAIL=your-email@example.com
ASSISTANT_LLM_PROVIDER=openai
